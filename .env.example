# Only explicit TerraFin entrypoints auto-load this file:
# - `terrafin-agent`
# - `python src/TerraFin/interface/server.py ...`

FRED_API_KEY=
TERRAFIN_HOST=127.0.0.1
TERRAFIN_PORT=8001
TERRAFIN_BASE_PATH=
TERRAFIN_CACHE_TIMEZONE=UTC

# Optional private-access endpoint used for dashboard / market-insights data.
TERRAFIN_PRIVATE_SOURCE_ENDPOINT=
TERRAFIN_PRIVATE_SOURCE_ACCESS_KEY=
TERRAFIN_PRIVATE_SOURCE_ACCESS_VALUE=
TERRAFIN_PRIVATE_SOURCE_TIMEOUT_SECONDS=10

# Optional SEC EDGAR contact identity for filings / 13F access.
TERRAFIN_SEC_USER_AGENT=Your Org Name sec-contact@example.com

# Optional MongoDB backend for TerraFin-local watchlist CRUD.
MONGODB_URI=
TERRAFIN_MONGODB_URI=
TERRAFIN_WATCHLIST_MONGODB_DATABASE=terrafin_status_db
TERRAFIN_WATCHLIST_MONGODB_COLLECTION=terrafin_watchlist
TERRAFIN_WATCHLIST_DOCUMENT_ID=terrafin_watchlist

# Optional API keys for agent / LLM experiments.
GEMINI_API_KEY=
OPENAI_API_KEY=
